# БДвал (PostgreSQL)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mval
POSTGRES_USER=mval
POSTGRES_PASSWORD=mval_secret

# Redis (Policy Cache)
REDIS_URL=redis://localhost:6379/0

# Ollama (Red Teaming LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Red Teaming Agent (sidecar)
REDTEAM_URL=http://localhost:8001
REDTEAM_TIMEOUT_SECONDS=15

# Policy Cache TTL
POLICY_CACHE_TTL_SECONDS=300

# Validation Gateway
VALIDATION_TIMEOUT_SECONDS=30
